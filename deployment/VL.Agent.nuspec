<?xml version="1.0"?>

<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>VL.Agent</id>
    <version>0.1.0-alpha</version>
    <title>VL.Agent</title>
    <authors>Philipp Parteder</authors>
    <projectUrl>https://github.com/prt-prt/VL.Agent</projectUrl>
    <repository type="git" url="https://github.com/prt-prt/VL.Agent.git" />
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Agentic development tools for vvvv gamma: an HDE editor bridge, MCP server, project indexer, and undo-integrated graph transactions.</description>
    <tags>VL vvvv gamma HDE MCP agent</tags>
    <license type="expression">MIT</license>
    <icon>icon\nugeticon.png</icon>
    <readme>docs\README.md</readme>
    <dependencies>
      <group targetFramework="net8.0-windows7.0">
        <dependency id="VL.HDE" version="[2025.7.2]" />
        <dependency id="VL.Skia" version="[2025.7.2]" />
        <dependency id="VL.CoreLib.Windows" version="[2025.7.2]" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="..\lib\**" target="lib\" exclude="..\lib\**\*.pdb" />
    <file src="..\*.vl" target="" />
    <file src="..\help\**" target="help\" />
    <file src="..\artifacts\tools\**" target="tools\" />
    <file src="..\schemas\**" target="schemas\" />
    <file src="..\examples\graph-transactions\**" target="examples\graph-transactions\" />
    <file src="nugeticon.png" target="icon\" />
    <file src="..\README.md" target="docs\" />
    <file src="..\docs\graph-transaction-protocol.md" target="docs\" />
    <file src="..\docs\reference\VL.Agent.md" target="docs\reference\" />
  </files>
</package>
